DATABASE_URL="postgresql://username:password@host/database?sslmode=require&pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://username:password@host/database?sslmode=require"
JWT_SECRET="your-secret-here"
# 期中報告 PDF 上傳用，Vercel Dashboard → Storage → Blob 建立後取得
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# === 自動上傳成績到 portalx（GitHub Actions worker）===
# 觸發 GitHub Actions 用的 fine-grained PAT（限本 repo、Actions: read/write）
GITHUB_DISPATCH_TOKEN="github_pat_xxxxxxxx"
# 目標 repo（owner/repo）
GITHUB_REPO="Eric920418/student-grades-system"
# worker 回報任務狀態的共用密鑰（與 GitHub Secret 同名同值，自行產生一組長亂數）
WORKER_CALLBACK_SECRET="generate-a-long-random-string"
