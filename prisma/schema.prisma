generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id        String   @id @default(cuid())
  studentId String   @unique  // 學號（全域唯一）
  name      String
  class     String   @default("A")
  createdAt DateTime @default(now())

  @@map("accounts")
}

model Course {
  id          String   @id @default(cuid())
  name        String   @unique // 課程名稱：3D電腦繪圖、互動投影
  code        String?  // 課程代碼：IC335
  description      String?  // 課程描述
  hasClassDivision Boolean  @default(false) // 是否啟用 A/B 分班
  allowStudentGrouping Boolean  @default(true) // 是否允許學生自助分組
  // portalx 課程對應（自動撈名單用）：例 IC411 / 學年114 / 學期2
  portalCosId      String?
  portalYear       String?
  portalSemester   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  students   Student[]
  groups     Group[]
  gradeItems GradeItem[]

  @@map("courses")
}

model Student {
  id        String   @id @default(cuid())
  name      String
  studentId String   // 移除全域唯一約束
  email     String?
  class     String   @default("A") // A班或B班
  courseId  String   // 課程ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentGroups StudentGroup[]
  grades        Grade[]

  @@unique([studentId, courseId]) // 同一課程內學號唯一
  @@map("students")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  courseId    String   // 課程ID
  reportUrl          String?   // 期中報告 PDF：Vercel Blob URL
  reportFileName     String?   // 期中報告 PDF：原始檔名
  reportUploadedAt   DateTime? // 期中報告 PDF：上傳時間
  reportUploadedById String?   // 期中報告 PDF：上傳者學號
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentGroups StudentGroup[]
  groupComments GroupComment[]

  @@unique([name, courseId]) // 同一課程內分組名稱唯一
  @@map("groups")
}

model StudentGroup {
  id        String   @id @default(cuid())
  studentId String
  groupId   String
  role      String?  // 職位：導演、模型、後製、動畫
  isLeader  Boolean  @default(false) // 是否為組長
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([studentId, groupId])
  @@map("student_groups")
}

model GradeItem {
  id       String @id @default(cuid())
  name     String
  weight   Float  @default(1.0)
  maxScore Float  @default(100.0)
  courseId String // 課程ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grades        Grade[]
  groupComments GroupComment[]

  @@unique([name, courseId]) // 同一課程內成績項目名稱唯一
  @@map("grade_items")
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  gradeItemId String
  score       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradeItem GradeItem @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)

  @@unique([studentId, gradeItemId])
  @@map("grades")
}

model GroupComment {
  id          String   @id @default(cuid())
  groupId     String
  gradeItemId String
  comment     String   // 老師給該組在該成績項目的評語
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  gradeItem GradeItem @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)

  @@unique([groupId, gradeItemId]) // 一組一個成績項目只有一則評語
  @@map("group_comments")
}

// 校務系統(portalx) 自動上傳成績的任務紀錄。
// 由 /api/portal-sync/dispatch 建立(pending)，GitHub Actions worker 透過
// /api/portal-sync/job-status 回報進度與結果。courseId/gradeItemId 以純字串保存
// （此表為任務日誌，不需外鍵級聯）。
model PortalUploadJob {
  id            String   @id @default(cuid())
  kind          String   @default("grades") // grades | roster
  courseId      String
  gradeItemId   String?  // roster 任務用不到
  gradeItemName String?  // roster 任務用不到
  status        String   @default("pending") // pending | running | success | failed
  dryRun        Boolean  @default(true)       // true=只填不送出（roster 不適用）
  filledCount   Int?
  totalCount    Int?
  message       String?  // 結果/錯誤訊息（完整顯示前端）
  screenshotUrl String?  // worker 截圖（上傳 Vercel Blob）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([courseId])
  @@map("portal_upload_jobs")
}