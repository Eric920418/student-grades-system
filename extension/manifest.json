{
  "manifest_version": 3,
  "name": "成績系統 — portalx 同步",
  "version": "2.0.0",
  "description": "在你已登入的瀏覽器裡自動爬取 portalx 所有課程與名單，結果送回成績系統。",
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*.yzu.edu.tw/*",
    "https://student-grades-system.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "portalx 同步"
  },
  "options_page": "options.html",
  "background": { "service_worker": "background.js" }
}
